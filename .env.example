SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,.railway.app,api.agencemenage.ma

# Database (PostgreSQL / Railway)
DATABASE_URL=postgres://user:password@host:port/dbname

# CORS & CSRF
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://agencemenage.ma,https://app.agencemenage.ma
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:5173,https://agencemenage.ma,https://app.agencemenage.ma

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Media files
MEDIA_ROOT=media/
MEDIA_URL=/media/
